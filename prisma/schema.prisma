generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Asset {
  id         String   @id @default(uuid())
  tenant_id  String
  title      String
  type       String   // SCORM, XAPI, PDF, SLIDES, LINK
  url        String
  metadata   String   // JSON string
  status     String   // UPLOADING, PROCESSING, READY, ERROR
  created_at DateTime @default(now())
}
